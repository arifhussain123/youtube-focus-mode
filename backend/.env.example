# Copy to .env (or export in your shell) before running the categorizer.
# Without this set, /api/categorize returns configured=false and skips work;
# everything else (event ingest, watch-time stats) works without it.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: switch databases without code changes (defaults to local SQLite).
# DATABASE_URL=postgresql+psycopg://user:pass@localhost/focus
