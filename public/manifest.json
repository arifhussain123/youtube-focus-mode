{
  "manifest_version": 3,
  "name": "YouTube Focus Mode",
  "version": "1.0.0",
  "description": "Hide YouTube distractions: recommendations, homepage feed, Shorts, comments, and end-screen suggestions.",
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:8000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "YouTube Focus Mode"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    }
  ]
}
